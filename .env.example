PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/REPLACE_WITH_YOUR_FORM_ID

# Google Analytics 4 Measurement ID. Format: G-XXXXXXXXXX
# Leave blank to disable analytics entirely (no gtag.js ever loads).
PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification string (HTML meta tag method).
# Only needed if verifying via URL property rather than DNS TXT.
PUBLIC_GSC_VERIFICATION=
