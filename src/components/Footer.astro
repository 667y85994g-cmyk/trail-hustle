---
import Logo from "./Logo.astro";
import {
  FACEBOOK_URL,
  INSTAGRAM_URL,
  LUMA_URL,
  REDDIT_URL,
  SUBSTACK_URL,
  WHATSAPP_URL,
  YOUTUBE_URL,
} from "../config";

const year = new Date().getFullYear();
---

<footer data-section="footer" class="footer relative">
  <div class="footer-inner">
    <div class="footer-logo-wrap">
      <Logo class="h-auto w-full" ariaLabel="Trail Hustle." />
    </div>

    <div class="footer-right">
      <p class="footer-brand font-display">Trail Hustle</p>
      <p class="footer-strapline font-body">
        A community built as a training ground.
      </p>
      <p class="footer-meta font-body">
        <span>© {year}</span>
        <span aria-hidden="true" class="footer-meta-dot">·</span>
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-ig"
          aria-label="Trail Hustle on Instagram"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.5" y2="6.5" />
          </svg>
          <span class="sr-only">Instagram</span>
        </a>
        <a
          href={SUBSTACK_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-substack"
          aria-label="Trail Hustle on Substack"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z" />
          </svg>
          <span class="sr-only">Substack</span>
        </a>
        <a
          href={LUMA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-luma"
          aria-label="Trail Hustle events on Luma"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          <span class="sr-only">Luma</span>
        </a>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-whatsapp"
          aria-label="Trail Hustle on WhatsApp"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          <span class="sr-only">WhatsApp</span>
        </a>
        <a
          href={FACEBOOK_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-facebook"
          aria-label="Trail Hustle on Facebook"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z" />
          </svg>
          <span class="sr-only">Facebook</span>
        </a>
        <a
          href={REDDIT_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-reddit"
          aria-label="Trail Hustle on Reddit"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 01-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 01.042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 014.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 01.14-.197.35.35 0 01.238-.042l2.906.617a1.214 1.214 0 011.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 00-.231.094.33.33 0 000 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 00.029-.463.33.33 0 00-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 00-.232-.095z" />
          </svg>
          <span class="sr-only">Reddit</span>
        </a>
        <a
          href={YOUTUBE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-youtube"
          aria-label="Trail Hustle on YouTube"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M21.58 7.19a2.51 2.51 0 0 0-1.77-1.77C18.25 5 12 5 12 5s-6.25 0-7.81.42a2.51 2.51 0 0 0-1.77 1.77A26.2 26.2 0 0 0 2 12a26.2 26.2 0 0 0 .42 4.81 2.51 2.51 0 0 0 1.77 1.77C5.75 19 12 19 12 19s6.25 0 7.81-.42a2.51 2.51 0 0 0 1.77-1.77A26.2 26.2 0 0 0 22 12a26.2 26.2 0 0 0-.42-4.81zM10 15V9l5 3z" />
          </svg>
          <span class="sr-only">YouTube</span>
        </a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    min-height: 30vh;
    border-top: 1px solid #d9d3c8;
    background-color: var(--color-paper);
  }

  .footer-inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    min-height: 30vh;
    padding: 2rem 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer-logo-wrap {
    width: 96px;
    flex-shrink: 0;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    text-align: right;
  }

  .footer-brand {
    font-size: 16px;
    color: var(--color-ink);
    margin: 0;
  }

  .footer-strapline {
    font-size: 13px;
    color: var(--color-ink-mute);
    margin: 0;
  }

  .footer-meta {
    margin: 4px 0 0;
    font-size: 12px;
    color: var(--color-ink-mute);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-meta-dot {
    color: var(--color-ink-mute);
  }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-ink-mute);
    transition: color 0.2s ease;
  }

  .footer-social-link + .footer-social-link {
    margin-left: 10px;
  }

  .footer-social-link:hover,
  .footer-social-link:focus-visible {
    color: var(--color-ink);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 767px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      padding: 40px 24px;
    }

    .footer-right {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>

<script>
  document
    .querySelector<HTMLAnchorElement>(".footer-ig")
    ?.addEventListener("click", () => {
      window.thTrack?.("instagram_click", { placement: "footer" });
    });

  document
    .querySelector<HTMLAnchorElement>(".footer-substack")
    ?.addEventListener("click", () => {
      window.thTrack?.("substack_click", { placement: "footer" });
    });

  document
    .querySelector<HTMLAnchorElement>(".footer-luma")
    ?.addEventListener("click", () => {
      window.thTrack?.("luma_click", { placement: "footer" });
    });

  document
    .querySelector<HTMLAnchorElement>(".footer-whatsapp")
    ?.addEventListener("click", () => {
      window.thTrack?.("whatsapp_click", { placement: "footer" });
    });

  document
    .querySelector<HTMLAnchorElement>(".footer-facebook")
    ?.addEventListener("click", () => {
      window.thTrack?.("facebook_click", { placement: "footer" });
    });

  document
    .querySelector<HTMLAnchorElement>(".footer-reddit")
    ?.addEventListener("click", () => {
      window.thTrack?.("reddit_click", { placement: "footer" });
    });

  document
    .querySelector<HTMLAnchorElement>(".footer-youtube")
    ?.addEventListener("click", () => {
      window.thTrack?.("youtube_click", { placement: "footer" });
    });
</script>
