---
import Logo from "./Logo.astro";
import { INSTAGRAM_URL } from "../config";

const year = new Date().getFullYear();
---

<footer data-section="footer" class="footer relative">
  <div class="footer-inner">
    <div class="footer-logo-wrap">
      <Logo class="h-auto w-full" ariaLabel="Trail Hustle." />
    </div>

    <div class="footer-right">
      <p class="footer-brand font-display">Trail Hustle</p>
      <p class="footer-strapline font-body">
        A community built as a training ground.
      </p>
      <p class="footer-meta font-body">
        <span>© {year}</span>
        <span aria-hidden="true" class="footer-meta-dot">·</span>
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-ig"
          aria-label="Trail Hustle on Instagram"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.5" y2="6.5" />
          </svg>
          <span class="sr-only">Instagram</span>
        </a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    min-height: 30vh;
    border-top: 1px solid #d9d3c8;
    background-color: var(--color-paper);
  }

  .footer-inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    min-height: 30vh;
    padding: 2rem 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer-logo-wrap {
    width: 96px;
    flex-shrink: 0;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    text-align: right;
  }

  .footer-brand {
    font-size: 16px;
    color: var(--color-ink);
    margin: 0;
  }

  .footer-strapline {
    font-size: 13px;
    color: var(--color-ink-mute);
    margin: 0;
  }

  .footer-meta {
    margin: 4px 0 0;
    font-size: 12px;
    color: var(--color-ink-mute);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-meta-dot {
    color: var(--color-ink-mute);
  }

  .footer-ig {
    display: inline-flex;
    align-items: center;
    color: var(--color-ink-mute);
    transition: color 0.2s ease;
  }

  .footer-ig:hover,
  .footer-ig:focus-visible {
    color: var(--color-ink);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 767px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      padding: 40px 24px;
    }

    .footer-right {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
