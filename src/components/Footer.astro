---
import Logo from "./Logo.astro";
import {
  INSTAGRAM_URL,
  LUMA_URL,
  SUBSTACK_URL,
  WHATSAPP_URL,
} from "../config";

const year = new Date().getFullYear();
---

<footer data-section="footer" class="footer relative">
  <div class="footer-inner">
    <div class="footer-logo-wrap">
      <Logo class="h-auto w-full" ariaLabel="Trail Hustle." />
    </div>

    <div class="footer-right">
      <p class="footer-brand font-display">Trail Hustle</p>
      <p class="footer-strapline font-body">
        A community built as a training ground.
      </p>
      <p class="footer-meta font-body">
        <span>© {year}</span>
        <span aria-hidden="true" class="footer-meta-dot">·</span>
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-ig"
          aria-label="Trail Hustle on Instagram"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.5" y2="6.5" />
          </svg>
          <span class="sr-only">Instagram</span>
        </a>
        <a
          href={SUBSTACK_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-substack"
          aria-label="Trail Hustle on Substack"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z" />
          </svg>
          <span class="sr-only">Substack</span>
        </a>
        <a
          href={LUMA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-luma"
          aria-label="Trail Hustle events on Luma"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          <span class="sr-only">Luma</span>
        </a>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link footer-whatsapp"
          aria-label="Trail Hustle on WhatsApp"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          <span class="sr-only">WhatsApp</span>
        </a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    min-height: 30vh;
    border-top: 1px solid #d9d3c8;
    background-color: var(--color-paper);
  }

  .footer-inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    min-height: 30vh;
    padding: 2rem 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer-logo-wrap {
    width: 96px;
    flex-shrink: 0;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    text-align: right;
  }

  .footer-brand {
    font-size: 16px;
    color: var(--color-ink);
    margin: 0;
  }

  .footer-strapline {
    font-size: 13px;
    color: var(--color-ink-mute);
    margin: 0;
  }

  .footer-meta {
    margin: 4px 0 0;
    font-size: 12px;
    color: var(--color-ink-mute);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-meta-dot {
    color: var(--color-ink-mute);
  }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-ink-mute);
    transition: color 0.2s ease;
  }

  .footer-social-link + .footer-social-link {
    margin-left: 10px;
  }

  .footer-social-link:hover,
  .footer-social-link:focus-visible {
    color: var(--color-ink);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 767px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      padding: 40px 24px;
    }

    .footer-right {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>

<script>
  document
    .querySelector<HTMLAnchorElement>(".footer-ig")
    ?.addEventListener("click", () => {
      window.thTrack?.("instagram_click", { placement: "footer" });
    });

  document
    .querySelector<HTMLAnchorElement>(".footer-substack")
    ?.addEventListener("click", () => {
      window.thTrack?.("substack_click", { placement: "footer" });
    });

  document
    .querySelector<HTMLAnchorElement>(".footer-luma")
    ?.addEventListener("click", () => {
      window.thTrack?.("luma_click", { placement: "footer" });
    });

  document
    .querySelector<HTMLAnchorElement>(".footer-whatsapp")
    ?.addEventListener("click", () => {
      window.thTrack?.("whatsapp_click", { placement: "footer" });
    });
</script>
