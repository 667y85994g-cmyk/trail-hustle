---
import { INSTAGRAM_URL, LUMA_URL, SUBSTACK_URL } from "../config";
---

<section
  data-section="waitlist"
  class="waitlist relative flex min-h-screen items-center justify-center overflow-hidden px-6"
>
  <div class="waitlist-block relative mx-auto w-full max-w-[640px] text-center">
    <h2
      class="waitlist-heading font-display leading-[1.05] tracking-tight text-ink"
    >
      The Log<span class="text-th-burnt-ochre">.</span>
    </h2>

    <p class="waitlist-subline mx-auto mt-5 font-body text-ink-mute">
      A letter a week. Subscribers get first word.
    </p>

    <a
      href={SUBSTACK_URL}
      target="_blank"
      rel="noopener noreferrer"
      data-waitlist-cta
      class="waitlist-cta mt-12 inline-flex items-center gap-2 font-display"
    >
      <span>Subscribe to The Log</span>
      <svg
        width="16"
        height="16"
        viewBox="0 0 14 14"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M3 7 L11 7 M7 3 L11 7 L7 11" />
      </svg>
    </a>

    <div class="waitlist-social mt-10 font-body text-ink-mute">
      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        data-waitlist-ig
        class="waitlist-social-link"
      >
        <span>or follow on Instagram</span>
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M3 7 L11 7 M7 3 L11 7 L7 11" />
        </svg>
      </a>
      <span aria-hidden="true" class="waitlist-social-dot">·</span>
      <a
        href={LUMA_URL}
        target="_blank"
        rel="noopener noreferrer"
        data-waitlist-luma
        class="waitlist-social-link"
      >
        <span>find events on Luma</span>
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M3 7 L11 7 M7 3 L11 7 L7 11" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .waitlist-heading {
    font-size: clamp(48px, 7vw, 96px);
    margin: 0;
  }

  .waitlist-subline {
    font-size: 18px;
    line-height: 1.5;
    max-width: 44ch;
  }

  .waitlist-cta {
    padding: 16px 32px;
    border-radius: 999px;
    background-color: var(--color-ink);
    color: var(--color-paper);
    font-size: 18px;
    line-height: 1.2;
    transition: background-color 0.2s ease;
    white-space: nowrap;
  }

  .waitlist-cta:hover,
  .waitlist-cta:focus-visible {
    background-color: #d15839;
  }

  .waitlist-social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    font-size: 14px;
  }

  .waitlist-social-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-ink-mute);
    transition: color 0.2s ease;
  }

  .waitlist-social-link:hover,
  .waitlist-social-link:focus-visible {
    color: var(--color-ink);
  }

  .waitlist-social-dot {
    color: var(--color-ink-mute);
  }
</style>

<script>
  document
    .querySelector<HTMLAnchorElement>("[data-waitlist-cta]")
    ?.addEventListener("click", () => {
      window.thTrack?.("substack_click", { placement: "waitlist_cta" });
    });

  document
    .querySelector<HTMLAnchorElement>("[data-waitlist-ig]")
    ?.addEventListener("click", () => {
      window.thTrack?.("instagram_click", { placement: "waitlist" });
    });

  document
    .querySelector<HTMLAnchorElement>("[data-waitlist-luma]")
    ?.addEventListener("click", () => {
      window.thTrack?.("luma_click", { placement: "waitlist" });
    });
</script>
