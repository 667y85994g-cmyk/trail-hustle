---
import "../styles/global.css";
import GroundTopography from "../components/GroundTopography.astro";
import Consent from "../components/Consent.astro";
import Analytics from "../components/Analytics.astro";
import {
  INSTAGRAM_URL,
  SITE_URL,
  SITE_NAME,
  SITE_TITLE,
  SITE_DESCRIPTION,
} from "../config";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  ogImage = "/og-image.png",
} = Astro.props;

const siteOrigin = Astro.site?.toString() ?? SITE_URL;
const canonicalURL = new URL(Astro.url.pathname, siteOrigin).toString();
const absoluteOg = new URL(ogImage, siteOrigin).toString();
const absoluteLogo = new URL("/logo-primary.png", siteOrigin).toString();
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION ?? "";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE_NAME,
  url: siteOrigin,
  logo: absoluteLogo,
  description: "The third place — driven people, on the trail, in good company. Built as a training ground.",
  sameAs: [INSTAGRAM_URL],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: siteOrigin,
  inLanguage: "en-GB",
};
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#F7F5F1" />
    {gscVerification && (
      <meta name="google-site-verification" content={gscVerification} />
    )}

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOg} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_GB" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOg} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
  </head>
  <body class="bg-paper text-ink font-body antialiased leading-[1.55]">
    <GroundTopography />
    <div class="relative z-10">
      <slot />
    </div>
    <Consent />
    <Analytics />

    <script>
      import { initScroll } from "../scripts/scroll";
      import { initGround } from "../scripts/ground";
      initScroll();
      initGround();
    </script>
  </body>
</html>
